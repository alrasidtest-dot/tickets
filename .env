# .env.example — documentation only
#
# This project does NOT load a .env file. A full .env system is intentionally
# out of scope for the current phases. This file exists only to document the
# database connection variables and to flag the dev-only credentials.
#
# The actual connection values live in config/database.php. The current values
# (root/root) are for LOCAL DEVELOPMENT ONLY and MUST be changed before any
# production deployment (use a dedicated DB user with a strong password and
# least-privilege grants).

DB_HOST=localhost
DB_PORT=3306
DB_NAME=it_helpdesk
DB_USER=root
DB_PASS=root
DB_CHARSET=utf8mb4
